<?xml version="1.0" encoding="utf-8"?>
<!--
  Sideload-channel-only manifest additions.

  The in-app updater downloads a newer signed APK from GitHub Releases (or a paired
  server's /dl) and hands it to the system package installer, which needs
  REQUEST_INSTALL_PACKAGES. That is exactly what Google Play's Device and Network Abuse
  policy prohibits ("self updates using any method other than Google Play's update
  mechanism"), so the permission lives here and NOT in main — the `play` flavor must never
  merge it, and its BuildConfig.UPDATER_ENABLED=false compiles the calling code out too.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

</manifest>
