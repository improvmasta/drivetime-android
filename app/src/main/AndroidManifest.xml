<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Robustness: resume logging after reboot / app update -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- No exact-alarm permission on purpose. USE_EXACT_ALARM is restricted by Play to
         alarm/clock/calendar apps, and SCHEDULE_EXACT_ALARM needs its own justification —
         neither is worth a policy fight for one feature. "Turn off tracking for N hours"
         still auto-resumes: Control.scheduleResumeAlarm asks canScheduleExactAlarms(),
         gets false, and uses setAndAllowWhileIdle. The resume can drift a few minutes in
         deep Doze; it does not get lost.

         REQUEST_INSTALL_PACKAGES is not here either, and is no longer declared by ANY
         flavor. It existed for the in-app updater, which is deleted: Play's Device and
         Network Abuse policy forbids an app updating itself by any route other than Play.
         Re-adding this permission is how the app gets taken down. -->
    <!-- Phase B: OBD over Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <!-- QR pairing scanner (AUTH.md). The camera is only used to scan a pairing QR; the
         ZXing CaptureActivity requests it at runtime. Not required so the app installs on
         camera-less devices (paste the device token instead). -->
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Motion-onset fast start (significant-motion + accelerometer). Optional: the app
         falls back to the GPS speed backstop on devices without these sensors. -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <application
        android:name=".DrivetimeApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="drivetime"
        android:supportsRtl="true"
        android:theme="@style/Theme.Drivetime">

        <!-- Launcher = the hybrid shell that hosts the SPA (the app *is* the web app).
             singleTask: a tapped event notification routes into the RUNNING instance via
             onNewIntent (NOTIFICATIONS.md P3) instead of stacking a second WebView. -->
        <activity
            android:name=".WebViewActivity"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Publishes Start/Stop/Toggle App Shortcuts for Samsung Modes & Routines
                 (they launch ControlActivity; the meta-data just has to live on the
                 launcher activity). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- The tracker's setup now lives in the SPA's Settings tabs (rendered in the
             WebViewActivity shell); the genuinely-native flows it needs — permission prompts,
             Bluetooth pairing, backup pickers, the QR scanner, the updater — are hosted by
             WebViewActivity itself and fired over the DrivetimeNative bridge. There is no
             separate native Tracker Activity any more. -->

        <activity
            android:name=".LogActivity"
            android:exported="false"
            android:label="Activity log" />

        <!-- Google Drive OAuth redirect (BACKUP.md). Google requires the custom scheme to
             be the REVERSED client id (a package-name scheme is rejected with
             redirect_uri_mismatch), so this filter is client-SPECIFIC — and each channel has
             its own client, because a Google Android client is bound to a signing SHA-1 and
             Play re-signs with its own key. ${driveRedirectScheme} is therefore a per-flavor
             placeholder derived from that flavor's client id (build.gradle.kts → driveClient);
             the two are set together so the scheme can never drift from the id it must match. -->
        <activity
            android:name=".OAuthRedirectActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay">
            <!-- tools:ignore=AppLinkUrlError — lint wants a host on any filter with a path,
                 but this is not an app link: it is Google's installed-app OAuth redirect,
                 which is scheme + path with NO host (DriveClient.redirectFor). Giving it a
                 host to satisfy lint changes the redirect_uri and Google answers every
                 backup sign-in with redirect_uri_mismatch. -->
            <intent-filter tools:ignore="AppLinkUrlError">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="${driveRedirectScheme}" android:path="/oauth2redirect" />
            </intent-filter>
        </activity>

        <service
            android:name=".LocationService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Routine/automation control: launch with one of the actions below. -->
        <activity
            android:name=".ControlActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="org.jupiterns.drivetime.action.START" />
                <action android:name="org.jupiterns.drivetime.action.STOP" />
                <action android:name="org.jupiterns.drivetime.action.TOGGLE" />
                <action android:name="org.jupiterns.drivetime.action.MODE_AUTO" />
                <action android:name="org.jupiterns.drivetime.action.MODE_DRIVING" />
                <action android:name="org.jupiterns.drivetime.action.MODE_ECO" />
                <action android:name="org.jupiterns.drivetime.action.SET" />
                <action android:name="org.jupiterns.drivetime.action.QUERY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".ControlReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="org.jupiterns.drivetime.action.START" />
                <action android:name="org.jupiterns.drivetime.action.STOP" />
                <action android:name="org.jupiterns.drivetime.action.TOGGLE" />
                <action android:name="org.jupiterns.drivetime.action.MODE_AUTO" />
                <action android:name="org.jupiterns.drivetime.action.MODE_DRIVING" />
                <action android:name="org.jupiterns.drivetime.action.MODE_ECO" />
                <action android:name="org.jupiterns.drivetime.action.SET" />
                <action android:name="org.jupiterns.drivetime.action.QUERY" />
            </intent-filter>
        </receiver>

        <!-- Auto start/stop: receives activity-recognition transitions -->
        <receiver
            android:name=".ActivityTransitionReceiver"
            android:exported="false" />

        <!-- Hands generated files (the mileage export, the report-a-problem diagnostic) to
             other apps via a content:// URI — a file:// URI is illegal to pass across
             processes on API 24+. See res/xml/file_paths.xml for the roots. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Robustness: resume logging after reboot / app update -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
