<?xml version="1.0" encoding="utf-8"?>
<!-- drivetime palette — DARK (night). Mirrors the SPA's frontend tokens.css :root
     (dark is the SPA default). Selected automatically when the system is in dark mode,
     matching the WebView, which follows the system theme via algorithmic darkening. -->
<resources>
    <color name="dt_bg">#0F0D0A</color>
    <color name="dt_surface_1">#171410</color>
    <color name="dt_surface_2">#1D1915</color>
    <color name="dt_surface_3">#282117</color>
    <color name="dt_border">#2B241C</color>
    <color name="dt_border_strong">#453C31</color>
    <color name="dt_text">#F5F1E8</color>
    <color name="dt_text_dim">#B9AD9B</color>
    <color name="dt_text_mut">#7D7466</color>
    <color name="dt_accent">#FFB454</color>
    <color name="dt_accent_strong">#FFCF8A</color>
    <!-- dark text on amber fills (SPA accent-contrast) -->
    <color name="dt_accent_contrast">#241A0C</color>

    <color name="status_green">#9ECF70</color>
    <color name="status_amber">#FFB454</color>
    <color name="status_red">#FF7368</color>
    <color name="status_blue">#6EA8FF</color>
    <color name="status_grey">#7D7466</color>

    <!-- warn at ~14% alpha (= SPA warn-soft dark) -->
    <color name="dt_warn_soft">#24FFD94D</color>
</resources>
