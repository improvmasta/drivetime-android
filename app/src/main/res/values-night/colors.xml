<?xml version="1.0" encoding="utf-8"?>
<!-- drivetime palette — DARK (night). Mirrors the SPA's frontend tokens.css :root
     (dark is the SPA default). Selected automatically when the system is in dark mode,
     matching the WebView, which follows the system theme via algorithmic darkening. -->
<resources>
    <color name="dt_bg">#000000</color>
    <color name="dt_surface_1">#0C0F14</color>
    <color name="dt_surface_2">#12161D</color>
    <color name="dt_surface_3">#1B212B</color>
    <color name="dt_border">#1E242E</color>
    <color name="dt_border_strong">#333C48</color>
    <color name="dt_text">#FFFFFF</color>
    <color name="dt_text_dim">#9FADBD</color>
    <color name="dt_text_mut">#616E7E</color>
    <color name="dt_accent">#56C8FF</color>
    <color name="dt_accent_strong">#8AD8FF</color>
    <!-- dark text on bright cyan fills (SPA accent-contrast) -->
    <color name="dt_accent_contrast">#04121C</color>

    <color name="status_green">#2EE6A8</color>
    <color name="status_amber">#FFB340</color>
    <color name="status_red">#FF5D6E</color>
    <color name="status_blue">#56C8FF</color>
    <color name="status_grey">#616E7E</color>

    <!-- warn at ~14% alpha (= SPA warn-soft dark) -->
    <color name="dt_warn_soft">#24FFB340</color>

    <!-- notification stat-tile wash: accent at ~15% alpha, over the dark shade -->
    <color name="dt_notif_chip">#2656C8FF</color>
</resources>
