<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Drivetime" parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- Settings screen building blocks: keeps cards / labels / inputs consistent
         without repeating attributes per row. -->
    <style name="SettingsSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>
    <style name="SettingsSectionBody">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>
    <style name="SectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:alpha">0.6</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <style name="SettingLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">10dp</item>
    </style>
    <style name="SettingHelp">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:alpha">0.7</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
    <style name="IntInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:inputType">number</item>
    </style>
</resources>
