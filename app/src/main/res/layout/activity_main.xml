<?xml version="1.0" encoding="utf-8"?>
<!-- The single native Tracker screen: live status + all setup in one place (the old
     Logger dashboard and Settings screen, merged). Ordered by how often it's touched:
     status → access/battery → devices → optional sync → updates → advanced → backup. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="drivetime"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tracking &amp; setup"
            android:textSize="13sp"
            android:alpha="0.7" />

        <!-- Actionable warning banner (one issue at a time) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/warningCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/dt_warn_soft"
            app:strokeColor="@color/status_amber"
            app:strokeWidth="1dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/warningText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/warningAction"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Fix" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ STATUS (live) ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:id="@+id/statusState"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:text="○ Tracking off" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/trackingSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/statusHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:textSize="12sp"
                    android:alpha="0.7"
                    android:text="Turn this on once. Tracking then runs in the background and detects driving vs. idle automatically — no need to start it each trip." />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:baselineAligned="false">

                    <Button
                        android:id="@+id/modeAuto"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Auto" />

                    <Button
                        android:id="@+id/modeDriving"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Driving" />

                    <Button
                        android:id="@+id/modeEco"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Eco" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Live OBD vitals (shown only when a dongle is configured) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/obdCard"
            style="@style/SettingsSection"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView
                    android:id="@+id/obdState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:text="○ OBD not connected" />

                <TextView
                    android:id="@+id/obdDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ ACCESS & BATTERY ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:baselineAligned="false">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PERMISSIONS &amp; ACCESS"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:textColor="@color/dt_text_dim" />

                    <Button
                        android:id="@+id/permsRecheck"
                        style="?attr/borderlessButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:text="Re-check" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/permsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="2dp" />

                <TextView style="@style/SectionHeader"
                    android:layout_marginTop="12dp"
                    android:text="BATTERY" />
                <TextView
                    android:id="@+id/batteryState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/batteryAdvice"
                    style="@style/SettingHelp" />
                <Button
                    android:id="@+id/batteryExempt"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Request battery exemption" />
                <Button
                    android:id="@+id/openOemPage"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Open OEM protected-apps page" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ DEVICES ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="DEVICES" />
                <TextView style="@style/SettingHelp" android:text="Pair your car's Bluetooth so connecting = &quot;I'm driving&quot; — the #1 reliable driving signal. Add an optional ELM327 OBD dongle for engine telemetry (RPM, coolant, fuel, fault codes)." />
                <Button
                    android:id="@+id/carBt"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Car Bluetooth: none" />
                <Button
                    android:id="@+id/obdDevice"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="OBD dongle: none" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ SYNC (OPTIONAL) ============ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/syncCard"
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="SYNC (OPTIONAL)" />
                <TextView style="@style/SettingHelp" android:text="Leave blank to stay fully on-device — drives are saved on your phone. To back up to a server, open its dashboard, go to Settings → Pair a device, and scan the QR (or paste the device token). A managed backup subscription is coming for those who'd rather not self-host." />

                <TextView style="@style/SettingLabel" android:text="Server URL" />
                <EditText
                    android:id="@+id/serverUrl"
                    style="@style/Widget.Dt.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://drivetime.example.com"
                    android:inputType="textUri" />

                <Button
                    android:id="@+id/scanQr"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Scan pairing QR" />

                <TextView style="@style/SettingLabel" android:text="Device token" />
                <EditText
                    android:id="@+id/deviceToken"
                    style="@style/Widget.Dt.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="scan the QR, or paste the token"
                    android:autofillHints="password"
                    android:inputType="textNoSuggestions" />

                <TextView
                    android:id="@+id/connState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/connDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/connError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    android:textSize="13sp"
                    android:textColor="@color/status_red"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/testConn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Test connection" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ UPDATES ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="UPDATES" />
                <TextView style="@style/SettingHelp" android:text="The app installs newer builds itself — no browser download or file hunting. Every build is signed with the same key, so an update lands in place and keeps your settings." />
                <TextView
                    android:id="@+id/versionLabel"
                    style="@style/SettingHelp"
                    android:layout_marginTop="4dp"
                    android:text="Installed version" />
                <CheckBox
                    android:id="@+id/updatesEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Check for updates automatically" />
                <Button
                    android:id="@+id/checkUpdates"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Check for updates now" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ ADVANCED (collapsed) ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView
                    android:id="@+id/advancedToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="▸  Advanced"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:clickable="true"
                    android:focusable="true" />

                <LinearLayout
                    android:id="@+id/advancedBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Drive detection -->
                    <TextView style="@style/SectionHeader"
                        android:layout_marginTop="10dp"
                        android:text="DRIVE DETECTION" />
                    <TextView style="@style/SettingHelp" android:text="How drivetime decides you're driving. Works in any car — no pairing required." />
                    <CheckBox
                        android:id="@+id/motionOnset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Fast start: detect motion to begin logging in any car (recommended)" />
                    <CheckBox
                        android:id="@+id/driveBySpeed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Use sustained GPS speed as a fallback drive trigger" />

                    <!-- Timing -->
                    <TextView style="@style/SectionHeader"
                        android:layout_marginTop="16dp"
                        android:text="TIMING" />
                    <TextView style="@style/SettingLabel" android:text="Driving fix interval (sec)" />
                    <TextView style="@style/SettingHelp" android:text="Seconds between GPS fixes while driving and moving." />
                    <EditText android:id="@+id/intervalSec" style="@style/IntInput" />

                    <TextView style="@style/SettingLabel" android:text="Idle fix interval (sec)" />
                    <TextView style="@style/SettingHelp" android:text="Sec between fixes while sitting at a red light, so a stop doesn't flood." />
                    <EditText android:id="@+id/idleIntervalSec" style="@style/IntInput" />

                    <TextView style="@style/SettingLabel" android:text="Light tier interval (sec)" />
                    <TextView style="@style/SettingHelp" android:text="Background pulse when you're not driving — keeps the timeline continuous, sips battery. The motion fast-start sits on top of this." />
                    <EditText android:id="@+id/lightIntervalSec" style="@style/IntInput" />

                    <TextView style="@style/SettingLabel" android:text="Light upload cadence (sec)" />
                    <TextView style="@style/SettingHelp" android:text="How often LIGHT-tier fixes are batched up and posted to the server." />
                    <EditText android:id="@+id/uploadIntervalSec" style="@style/IntInput" />

                    <TextView style="@style/SettingLabel" android:text="Driving upload cadence (sec)" />
                    <TextView style="@style/SettingHelp" android:text="How often DRIVING-tier fixes are flushed — short for near-real-time position on the dashboard / Auto pane." />
                    <EditText android:id="@+id/drivingUploadIntervalSec" style="@style/IntInput" />

                    <TextView style="@style/SettingLabel" android:text="Stationary trip-end (min)" />
                    <TextView style="@style/SettingHelp" android:text="Auto-trip backstop: end a trip after this many minutes stationary. 0 disables." />
                    <EditText android:id="@+id/stationaryStopMin" style="@style/IntInput" />

                    <!-- Automation -->
                    <TextView style="@style/SectionHeader"
                        android:layout_marginTop="16dp"
                        android:text="AUTOMATION" />
                    <CheckBox
                        android:id="@+id/autoTrip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Auto start/stop with Android activity-recognition" />
                    <TextView style="@style/SettingHelp" android:text="Off by default — its slow-traffic car/bike guess is the unreliable part we avoid. Leave car-BT / OBD as the trigger." />

                    <TextView style="@style/SettingLabel" android:text="Control token (optional)" />
                    <TextView style="@style/SettingHelp" android:text="If set, SET / QUERY intents must include token=&lt;this&gt;. START/STOP/TOGGLE stay open." />
                    <EditText
                        android:id="@+id/controlToken"
                        style="@style/Widget.Dt.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="blank = open"
                        android:inputType="text" />

                    <TextView style="@style/SettingLabel"
                        android:paddingTop="12dp"
                        android:text="Routine API cheat-sheet" />
                    <TextView
                        android:id="@+id/cheatSheet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:typeface="monospace"
                        android:textSize="12sp"
                        android:textIsSelectable="true"
                        android:paddingTop="4dp" />

                    <!-- Notifications -->
                    <TextView style="@style/SectionHeader"
                        android:layout_marginTop="16dp"
                        android:text="NOTIFICATIONS" />
                    <CheckBox
                        android:id="@+id/alerts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Commute &amp; fault-code alerts" />
                    <TextView style="@style/SettingHelp" android:text="Polls /api/alerts every 15 minutes and posts a notification when something fires. Needs a server." />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ============ BACKUP ============ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">

            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="BACKUP" />
                <TextView style="@style/SettingHelp" android:text="Save these settings to a JSON file you can restore on a new phone or push from a routine. Includes login (be careful where you store it)." />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <Button
                        android:id="@+id/exportSettings"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Export…" />
                    <Button
                        android:id="@+id/importSettings"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Import…" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/viewLog"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="32dp"
            android:text="Activity log" />

    </LinearLayout>
</ScrollView>
