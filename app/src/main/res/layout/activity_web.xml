<?xml version="1.0" encoding="utf-8"?>
<!--
  The hybrid shell: the drivetime SPA fills the screen (its own tab bar is the only
  navigation), a status pill in the top-right corner — sitting in the SPA header band,
  which keeps its own controls to the left to leave room — reports the logger and taps
  through to the SPA's own Settings route (the tracker settings live there as tabs), and
  an overlay covers the WebView when the dashboard can't load offline.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top-right chip in the header band: one-tap, on-phone entry to the native logger,
         also a glanceable "is it logging". -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/pillCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <TextView
            android:id="@+id/pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:text="●" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Setup-needed / offline cover. Hidden while the dashboard is up. -->
    <LinearLayout
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="?android:attr/colorBackground"
        android:visibility="gone">

        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:textSize="14sp"
            android:alpha="0.8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlayBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</FrameLayout>
