<?xml version="1.0" encoding="utf-8"?>
<!--
  The hybrid shell: the drivetime SPA fills the screen (its own tab bar is the only
  navigation, and its header now carries the tracking on/off + mode buttons), and an
  overlay covers the WebView when the dashboard can't load offline.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Setup-needed / offline cover. Hidden while the dashboard is up. -->
    <LinearLayout
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="?android:attr/colorBackground"
        android:visibility="gone">

        <TextView
            android:id="@+id/overlayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:textSize="14sp"
            android:alpha="0.8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/overlayBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp" />
    </LinearLayout>
</FrameLayout>
