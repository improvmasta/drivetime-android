<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Connection -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="CONNECTION" />

                <TextView style="@style/SettingLabel" android:text="Server URL" />
                <TextView style="@style/SettingHelp" android:text="The drivetime dashboard your phone uploads to." />
                <EditText
                    android:id="@+id/serverUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://drivetime.example.com"
                    android:inputType="textUri" />

                <TextView style="@style/SettingLabel" android:text="Username" />
                <EditText
                    android:id="@+id/username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="username"
                    android:inputType="text" />

                <TextView style="@style/SettingLabel" android:text="Password" />
                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:inputType="textPassword" />

                <TextView
                    android:id="@+id/testResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:paddingTop="6dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/testConn"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Test connection" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tracking -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="TRACKING" />

                <TextView style="@style/SettingLabel" android:text="Driving fix interval (sec)" />
                <TextView style="@style/SettingHelp" android:text="Seconds between GPS fixes while driving and moving." />
                <EditText android:id="@+id/intervalSec" style="@style/IntInput" />

                <TextView style="@style/SettingLabel" android:text="Idle fix interval (sec)" />
                <TextView style="@style/SettingHelp" android:text="Sec between fixes while sitting at a red light, so a stop doesn't flood." />
                <EditText android:id="@+id/idleIntervalSec" style="@style/IntInput" />

                <TextView style="@style/SettingLabel" android:text="Light tier interval (sec)" />
                <TextView style="@style/SettingHelp" android:text="Background pulse when you're not driving — keeps the timeline continuous, sips battery." />
                <EditText android:id="@+id/lightIntervalSec" style="@style/IntInput" />

                <TextView style="@style/SettingLabel" android:text="Light upload cadence (sec)" />
                <TextView style="@style/SettingHelp" android:text="How often LIGHT-tier fixes are batched up and posted to the server." />
                <EditText android:id="@+id/uploadIntervalSec" style="@style/IntInput" />

                <TextView style="@style/SettingLabel" android:text="Driving upload cadence (sec)" />
                <TextView style="@style/SettingHelp" android:text="How often DRIVING-tier fixes are flushed — short for near-real-time position on the dashboard / Auto pane." />
                <EditText android:id="@+id/drivingUploadIntervalSec" style="@style/IntInput" />

                <TextView style="@style/SettingLabel" android:text="Stationary trip-end (min)" />
                <TextView style="@style/SettingHelp" android:text="Auto-trip backstop: end a trip after this many minutes stationary. 0 disables." />
                <EditText android:id="@+id/stationaryStopMin" style="@style/IntInput" />

                <CheckBox
                    android:id="@+id/driveBySpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Use sustained GPS speed as a fallback drive trigger" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OBD -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="OBD" />
                <TextView style="@style/SettingHelp" android:text="Optional ELM327 Bluetooth dongle — adds engine telemetry (RPM, coolant, fuel, fault codes) to every drive." />
                <Button
                    android:id="@+id/obdDevice"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="OBD dongle: none" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Automation -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="AUTOMATION" />
                <TextView style="@style/SettingHelp" android:text="Pair the car's head unit so connecting Bluetooth = &quot;I'm driving&quot;. The #1 reliable driving signal." />
                <Button
                    android:id="@+id/carBt"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Car Bluetooth: none" />

                <CheckBox
                    android:id="@+id/autoTrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Auto start/stop with Android activity-recognition" />
                <TextView style="@style/SettingHelp" android:text="Off by default — its slow-traffic car/bike guess is the unreliable part we avoid. Leave car-BT / OBD as the trigger." />

                <TextView style="@style/SettingLabel" android:text="Control token (optional)" />
                <TextView style="@style/SettingHelp" android:text="If set, SET / QUERY intents must include token=&lt;this&gt;. START/STOP/TOGGLE stay open." />
                <EditText
                    android:id="@+id/controlToken"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="blank = open"
                    android:inputType="text" />

                <TextView style="@style/SettingLabel"
                    android:paddingTop="12dp"
                    android:text="Routine API cheat-sheet" />
                <TextView
                    android:id="@+id/cheatSheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:typeface="monospace"
                    android:textSize="12sp"
                    android:textIsSelectable="true"
                    android:paddingTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Notifications -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="NOTIFICATIONS" />
                <CheckBox
                    android:id="@+id/alerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Commute &amp; fault-code alerts" />
                <TextView style="@style/SettingHelp" android:text="Polls /api/alerts every 15 minutes and posts a notification when something fires." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Battery -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="BATTERY" />
                <TextView
                    android:id="@+id/batteryState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/batteryAdvice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/SettingHelp" />
                <Button
                    android:id="@+id/batteryExempt"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Request battery exemption" />
                <Button
                    android:id="@+id/openOemPage"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Open OEM protected-apps page" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Import/export -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SettingsSection"
            android:layout_marginTop="12dp">
            <LinearLayout style="@style/SettingsSectionBody">

                <TextView style="@style/SectionHeader" android:text="BACKUP" />
                <TextView style="@style/SettingHelp" android:text="Save these settings to a JSON file you can restore on a new phone or push from a routine. Includes login (be careful where you store it)." />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <Button
                        android:id="@+id/exportSettings"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Export…" />
                    <Button
                        android:id="@+id/importSettings"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Import…" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="32dp"
            android:text="Save" />

    </LinearLayout>
</ScrollView>
