<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background: the current icon set's navy tile gradient (diagonal
     #1a2c45 → #0c1626, sampled from design/appicon's with-background dark tile), so
     the transparent-padded foreground D sits on the same field as every other icon
     surface (PWA maskable, wizard hero, app-bar). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:startColor="#1a2c45"
                android:endColor="#0c1626" />
        </aapt:attr>
    </path>
</vector>
