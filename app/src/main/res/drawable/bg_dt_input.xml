<?xml version="1.0" encoding="utf-8"?>
<!-- Boxed text field = the SPA's .dt-input: surface-3 fill, 1dp hairline border rounded
     to the r-sm radius (10dp), and an accent border on focus. Replaces the dated underline. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/dt_surface_3" />
            <stroke android:width="1dp" android:color="@color/dt_accent" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dt_surface_3" />
            <stroke android:width="1dp" android:color="@color/dt_border" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
