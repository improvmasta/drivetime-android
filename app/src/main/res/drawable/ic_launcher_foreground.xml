<?xml version="1.0" encoding="utf-8"?>
<!-- "D on a road" mark: a cyan capital D (#4cc2ff) standing on a perspective road.
     Drawn within the 72x72 adaptive safe zone; the road bleeds toward the edges and
     is clipped by the launcher mask. -->
