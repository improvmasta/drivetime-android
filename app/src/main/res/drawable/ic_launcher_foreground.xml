    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- road: a perspective ribbon receding to the horizon -->
    <path android:pathData="M6,104 L102,104 L59,48 L49,48 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="104"
                android:endX="54" android:endY="48"
                android:startColor="#4E6683"
                android:endColor="#2E3E52" />
        </aapt:attr>
    </path>
    <!-- centre line: perspective dashes in front of the D -->
    <path android:fillColor="#EAF1F8" android:pathData="M49,100 L59,100 L57.6,90 L50.4,90 Z" />
    <path android:fillColor="#EAF1F8" android:pathData="M51,88 L57,88 L56.1,80 L51.9,80 Z" />
    <!-- D: standing on the road -->
    <path
        android:fillColor="#4CC2FF"
        android:fillType="evenOdd"
        android:pathData="M38,34 L50,34 C62,34 70,42 70,54 C70,66 62,74 50,74 L38,74 Z M45,41 L50,41 C59,41 63,46 63,54 C63,62 59,67 50,67 L45,67 Z" />
